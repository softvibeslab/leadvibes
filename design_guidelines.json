  "universal_guidelines": [
    "Always use 'Outfit' for headings and 'Plus Jakarta Sans' for body text.",
    "Buttons should be pill-shaped (rounded-full) for a modern, friendly feel.",
    "Use 2-3x more padding than standard to create a 'luxurious' expansive feel.",
    "Implement the 'Selva Green' (#059669) as the primary brand color.",
    "Use glassmorphism effects for the AI Assistant chat widget.",
    "Ensure the Leaderboard is visually distinct with Gold/Silver/Bronze accents.",
    "Do NOT use generic gradients. Use the specific emerald-to-teal gradients if needed.",
    "Images must be high-quality, aspirational, and reflect the Tulum/Jungle aesthetic."
  ],
  "instructions_to_main_agent": [
    "1. Setup Tailwind theme extending colors with the 'Tulum Jungle' palette.",
    "2. Install 'Outfit' and 'Plus Jakarta Sans' fonts.",
    "3. Create the 'Sidebar' component with a tropical touch (maybe a leaf logo).",
    "4. Build the 'Dashboard' with a Bento Grid layout using the defined cards.",
    "5. Implement the 'AI Assistant' as a floating widget with glassmorphism.",
    "6. Use 'recharts' for the sales charts, styled with the theme colors.",
    "7. Create the 'Gamification' components (Leaderboard, Badges) with high visual impact."
  ]
}