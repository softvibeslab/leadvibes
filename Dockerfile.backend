FROM python:3.13-slim

WORKDIR /app

# Install system dependencies (including curl for moai install)
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install MoAI-ADK
RUN curl -fsSL https://raw.githubusercontent.com/modu-ai/moai-adk/main/install.sh | bash \
    && export PATH="$HOME/.local/bin:$PATH" \
    && moai version

# Ensure PATH is set for all subsequent commands
ENV PATH="/root/.local/bin:${PATH}"

# Copy requirements first for caching
COPY backend/requirements.txt .
# Install dependencies, skipping unavailable packages
RUN grep -v "emergentintegrations" requirements.txt > requirements_filtered.txt \
    && pip install --no-cache-dir -r requirements_filtered.txt

# Create mock for emergentintegrations package
RUN mkdir -p /root/.local/lib/python3.13/site-packages/emergentintegrations/llm && \
    echo "# Mock package" > /root/.local/lib/python3.13/site-packages/emergentintegrations/__init__.py && \
    echo "# Mock LLM" > /root/.local/lib/python3.13/site-packages/emergentintegrations/llm/__init__.py

COPY mock_emergent.py /root/.local/lib/python3.13/site-packages/emergentintegrations/llm/chat.py

# Copy backend code
COPY backend/ .

# Expose port
EXPOSE 8000

# Run the application
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
